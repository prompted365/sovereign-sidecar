# Sovereign Sidecar — Chamber v0.1 Example
#
# This is a session-scoped pointer surface. The router (hooks/sidecar-router.py)
# reads this file at every UserPromptSubmit and injects the matched lane's PROTOCOL
# as a readable directive — the model runs that lane inline — when arrow confidence
# exceeds disposition_bias. (Earlier versions emitted a machine KV tag and relied on
# a downstream hook; that consumer was never universal, so the model is now the
# consumer and the directive carries the lane's actual reasoning.)
#
# Default discovery paths (router checks in order):
#   1. $SIDECAR_CHAMBER (environment variable)
#   2. ~/.sidecar/chamber.yaml
#   3. ~/.claude/sidecar/chamber.yaml
#   4. .sidecar/chamber.yaml (project-local)
#
# Copy this file to one of those locations and edit the disposition_bias
# values + the disposition free-text to shape arrow firing for the current
# session.

schema_version: "0.1"

# Current session posture. Updates on [Posture → X/Y] toggle detected by router.
# Format: <ENG|OPS>/<DIRECT|META>
posture: "ENG/DIRECT"

# /tom-compressed session trajectory. Tells the quiver what it's biased toward,
# not what to do. Refreshes on session start and posture shift only — not on
# every message.
disposition: |
  implementation-heavy; bias complement+counter;
  suppress ingest (context stable);
  publication not imminent (citation-intel low priority)

# ----------------------------------------------------------------------
# Arrows — user-facing governance primitives
# ----------------------------------------------------------------------
#
# Each arrow has:
#   pointer        — path to skill body (resolved relative to sidecar root)
#   tom_briefing   — one-line description of when this arrow should fire NOW
#   disposition_bias — threshold (0.0-1.0); arrow fires when router confidence > bias
#   fires          — semantic trigger condition
#   stance         — arrow's adversarial / cooperative / metabolizing posture
#
# Tune disposition_bias to match the session's needs. Router confidence scales with how many
# trigger patterns match: ONE match ≈ base×0.65 (~0.50), TWO ≈ base×0.85 (~0.68), THREE+ ≈ base
# (~0.78). An arrow fires when confidence > bias. So in practice:
#   bias 0.0-0.45 = aggressive   (a single trigger match fires it)
#   bias 0.5-0.65 = balanced     (needs ~two corroborating matches)
#   bias 0.7-0.9  = conservative (needs a strong, multi-signal match)
#   bias 1.0      = suppressed   (never fires this session)
# (Pre-tic-308 the gate was inert — single matches fired everything regardless of bias. These
# defaults assume the recalibrated confidence gate in hooks/sidecar-router.py:assess_intent.)

arrows:
  ingest:
    pointer: "skills/ingest/SKILL.md"
    tom_briefing: "metabolize — fire when external context enters the session"
    disposition_bias: 0.4
    fires: "before_context_enters"
    stance: "metabolize"

  tom:
    pointer: "skills/tom/SKILL.md"
    tom_briefing: "centroid-preserving re-expression — fire before publication or audience shift"
    disposition_bias: 0.45
    fires: "before_expression"
    stance: "centroid_preserving"

  complement:
    pointer: "skills/complement/SKILL.md"
    tom_briefing: "topological closure — fire when a move lands and exposed surfaces aren't named"
    disposition_bias: 0.6
    fires: "after_move_lands"
    stance: "cooperative_topological"

  counter:
    pointer: "skills/counter/SKILL.md"
    tom_briefing: "adversarial falsification — fire before committing to an architecture or irreversible decision"
    disposition_bias: 0.5
    fires: "before_move_commits"
    stance: "adversarial_falsifying"

  citation_intel:
    pointer: "skills/citation-intel/SKILL.md"
    tom_briefing: "publication readiness — fire before publishing content to AI-searchable surfaces"
    disposition_bias: 0.5
    fires: "before_publication"
    stance: "readiness_check"

  posture:
    pointer: "skills/posture/SKILL.md"
    tom_briefing: "working-mode contract — fire when next move could mutate state and posture is META"
    disposition_bias: 0.5
    fires: "before_mutation_under_meta"
    stance: "contract_declaration"

  delegate:
    pointer: "skills/delegate/SKILL.md"   # full protocol in the skill; compressed directive in LANE_DIRECTIVES
    tom_briefing: "govern the swarm spec — fire before fanning a goal out to subagents"
    disposition_bias: 0.55
    fires: "before_fan_out"
    stance: "swarm_governing"

  preflight:
    pointer: "skills/preflight/SKILL.md"
    tom_briefing: "repo-native pre-mutation gate — fire on operator momentum before the agent mutates"
    disposition_bias: 0.4
    fires: "before_mutation"
    stance: "preflight_obstacle_avoidance"

# ----------------------------------------------------------------------
# Support arrows — not user-facing; fill the chamber
# ----------------------------------------------------------------------

support:
  tactical_hydration:
    pointer: "skills/tactical-hydration/SKILL.md"
    role: "discover pointer targets at session start"

  consolidate:
    pointer: "skills/consolidate/SKILL.md"
    role: "package discovered targets into chamber-consumable form"

# ----------------------------------------------------------------------
# Fill provenance
# ----------------------------------------------------------------------

refreshed_at: null               # ISO timestamp of last fill; set by fill protocol
fill_source: null                # session_start | posture_shift | manual
