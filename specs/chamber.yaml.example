# Sovereign Sidecar — Chamber v0.2 Example (layered: structured base + LLM enrich)
#
# The chamber is the sidecar's ONLY organ for holding constitutional state — the
# stateless cousin of Ubiquity's harmony disposition. It is NOT a cheap pointer index
# to skim; crafting it well is the highest-leverage spend in the system. Full design:
# specs/chamber-v2.md.
#
# DO NOT hand-tune this file as your daily driver. Generate it:
#     python3 hooks/chamber_fill.py --trigger session_start --enrich \
#         --root /path/to/your/repo --out ~/.sidecar/chamber.yaml
# chamber_fill writes L1 (cheap, always-on, no LLM) and — when triggered — L2 (an
# LLM enrich pass that resolves mode, writes the constitutional backdrop, and DERIVES
# the per-arrow biases). This file is a worked EXAMPLE of the shape it produces.
#
# Router discovery paths (in order): $SIDECAR_CHAMBER, ~/.sidecar/chamber.yaml,
# ~/.claude/sidecar/chamber.yaml, .sidecar/chamber.yaml.
#
# Degradation ladder (fail-soft, never worse than v1):
#   L1 + L2 fresh → full backdrop; biases derived; mode resolved.
#   L1 only       → coarse backdrop; mode `unresolved`; biases = conservative defaults.
#   no chamber    → router fail-soft to raw pattern match.

schema_version: "0.2"

# ---------------------------------------------------------------------------
# L1 — structured base (cheap, always-on, no LLM). The floor the sidecar never
# goes blind below. Inferred from cwd / git-state / repo-shape / explicit toggle.
# ---------------------------------------------------------------------------

# Posture LEAN. An explicit `[Posture → X/Y]` toggle resolves it (source: toggle);
# otherwise L1 infers a lean (source: inferred|default). Format: <ENG|OPS>/<DIRECT|META>.
posture:
  value: "ENG/DIRECT"
  source: "toggle"          # toggle | inferred | default
  confidence: 0.95

# Working MODE. L1 only HINTS mode (cwd/git can't reliably resolve DIRECT vs META);
# L2 (or an explicit toggle) RESOLVES it. When source is `hinted`/`unresolved` the
# router gates conservatively and surfaces "UNRESOLVED" in the directive.
mode:
  value: "DIRECT"
  source: "resolved"        # resolved (L2/toggle) | hinted (L1) | unresolved

# STAKES — a structured signal, not a guess. `signals` is the cheap evidence:
# dirty files on risky paths + invariant hotspots present in the repo.
stakes:
  level: "elevated"         # low | elevated | high
  signals:
    - "hotspot:charge"
    - "hotspot:refund"
    - "risky_path:migrations/"

# REPO SHAPE — L1 evidence (cheap, no LLM). invariant_hotspots are grep-derived
# co-write surfaces: concept words whose multiple writers form a coupled invariant.
repo_shape:
  root: "/path/to/your/repo"
  languages: ["ts", "sql"]
  invariant_hotspots: ["charge", "refund", "ledger"]
  git_dirty: true

# ---------------------------------------------------------------------------
# L2 — enriched constitutional backdrop (the stateless cousin of harmony disposition).
# Written by the LLM enrich pass. NOT a one-liner: the shape of the work, what it is
# biased toward, and WHY. The router surfaces this to the model as the [backdrop]
# preamble the firing lanes run against.
# ---------------------------------------------------------------------------
disposition:
  text: |
    Money-path refactor under crash-atomicity pressure; coupled writers span
    charge / refund / ledger. Bias preflight + complement HARD (blast-radius breadth
    is the live risk — un-named siblings share the non-atomic invariant). Counter on
    irreversible schema / txn-boundary calls. Suppress ingest (context is stable).
  meaning_state: "strained"    # preserved | strained | dissonant
  derived_at: "2026-05-30T05:00:00Z"

# ---------------------------------------------------------------------------
# Arrows. `bias` is DERIVED at fill time from (disposition_lean, posture, mode,
# stakes, repo_shape) — NOT hand-tuned magic floats (spec §4). Lower bias = fires
# more easily. `live_context` is the L2 "what this lane means RIGHT NOW for THIS
# work" line, woven into the lane directive. `disposition_lean` (hard|soft|suppress)
# records the L2 judgment the bias derivation consumed.
#
# Router confidence scales with match density: ONE match ≈ base×0.65 (~0.50),
# TWO ≈ base×0.85 (~0.68), THREE+ ≈ base (~0.78). An arrow fires when confidence > bias.
# ---------------------------------------------------------------------------
arrows:
  ingest:
    pointer: "skills/ingest/SKILL.md"
    bias: 0.55                 # base 0.40 + soft 0.15 (context stable → suppress)
    stance: "metabolize"
    disposition_lean: "soft"

  tom:
    pointer: "skills/tom/SKILL.md"
    bias: 0.45                 # base, neutral
    stance: "centroid_preserving"

  complement:
    pointer: "skills/complement/SKILL.md"
    bias: 0.35                 # base 0.55 − hard 0.20
    stance: "cooperative_topological"
    live_context: "every ledger_entries writer must be swept before this lands — refund.ts is the un-named coupled sibling"
    disposition_lean: "hard"

  counter:
    pointer: "skills/counter/SKILL.md"
    bias: 0.23                 # base 0.50 − hard 0.20 − elevated 0.07
    stance: "adversarial_falsifying"
    live_context: "falsify on irreversible txn-boundary / schema calls — quote the table the lock granularity assumes"
    disposition_lean: "hard"

  citation_intel:
    pointer: "skills/citation-intel/SKILL.md"
    bias: 0.50                 # base, neutral (publication not the focus this session)
    stance: "readiness_check"

  delegate:
    pointer: "skills/delegate/SKILL.md"
    bias: 0.55                 # base, neutral
    stance: "swarm_governing"

  preflight:
    pointer: "skills/preflight/SKILL.md"
    bias: 0.23                 # base 0.45 − DIRECT 0.10 − elevated 0.07 − hotspots 0.05
    stance: "preflight_obstacle_avoidance"
    live_context: "grep every co-writer of ledger_entries before any charge/refund mutation; a list of one means you under-searched"

  # posture is toggle-detected, not bias-gated.
  posture:
    pointer: "skills/posture/SKILL.md"
    stance: "contract_declaration"

# ---------------------------------------------------------------------------
# Support arrows — not user-facing; they fill the chamber.
# ---------------------------------------------------------------------------
support:
  tactical_hydration:
    pointer: "skills/tactical-hydration/SKILL.md"
    role: "discover pointer targets at fill"
  consolidate:
    pointer: "skills/consolidate/SKILL.md"
    role: "package discovered targets into chamber-consumable form"

# ---------------------------------------------------------------------------
# Provenance + control.
# layers_present tells the router what it is standing on (L1 only → gate conservatively).
# refreshed_at + the fill TTL guard staleness (Volatility Handling Law).
# muted is honored by the SIDECAR_MUTE contract (env SIDECAR_MUTE OR-merged with this).
# ---------------------------------------------------------------------------
refreshed_at: "2026-05-30T05:00:00Z"
fill_source: "session_start"     # session_start | posture_shift | stakes_crossed | manual
layers_present: ["L1", "L2"]
muted: []
